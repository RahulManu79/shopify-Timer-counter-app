{% comment %}
  Countdown Timer Block
  Preact-based widget that displays countdown timers on product pages.
  The JavaScript is built from src/ via esbuild and loaded as a compiled asset.
{% endcomment %}

<div
  id="helixo-countdown-timer"
  data-shop="{{ shop.permanent_domain }}"
  data-product-id="{{ product.id }}"
  data-collection-ids="{% for collection in product.collections %}{{ collection.id }}{% unless forloop.last %},{% endunless %}{% endfor %}"
  style="display:none;"
>
</div>

<style>
  #helixo-countdown-timer {
    margin: 12px 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  /* Shown once Preact mounts content */
  #helixo-countdown-timer:not(:empty) {
    display: block !important;
  }
  .helixo-timer-wrapper {
    padding: 16px;
    border-radius: 8px;
    text-align: center;
  }
  .helixo-timer-label {
    font-size: 14px;
    margin-bottom: 10px;
    font-weight: 500;
  }
  .helixo-timer-digits {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
  }
  .helixo-timer-unit { text-align: center; }
  .helixo-timer-value {
    display: inline-block;
    padding: 8px 12px;
    border-radius: 6px;
    font-size: 26px;
    font-weight: 700;
    min-width: 50px;
    font-variant-numeric: tabular-nums;
  }
  .helixo-timer-unit-label {
    display: block;
    font-size: 10px;
    margin-top: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .helixo-timer-separator {
    font-size: 24px;
    font-weight: 700;
    padding-bottom: 18px;
  }
  .helixo-timer-urgency {
    margin-top: 10px;
    font-size: 13px;
    font-weight: 600;
  }
  /* Size variants */
  .helixo-size-small .helixo-timer-wrapper { padding: 10px; }
  .helixo-size-small .helixo-timer-label { font-size: 11px; }
  .helixo-size-small .helixo-timer-value { font-size: 18px; padding: 5px 8px; min-width: 36px; }
  .helixo-size-small .helixo-timer-unit-label { font-size: 8px; }
  .helixo-size-small .helixo-timer-separator { font-size: 16px; }
  .helixo-size-large .helixo-timer-wrapper { padding: 22px; }
  .helixo-size-large .helixo-timer-label { font-size: 18px; }
  .helixo-size-large .helixo-timer-value { font-size: 36px; padding: 12px 18px; min-width: 65px; }
  .helixo-size-large .helixo-timer-unit-label { font-size: 12px; }
  .helixo-size-large .helixo-timer-separator { font-size: 32px; }
  /* Urgency animations */
  @keyframes helixo-color-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
  @keyframes helixo-flash { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
  @keyframes helixo-shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-3px); } 75% { transform: translateX(3px); } }
  .helixo-urgency-color_pulse { animation: helixo-color-pulse 1.5s ease-in-out infinite; }
  .helixo-urgency-flash { animation: helixo-flash 0.8s ease-in-out infinite; }
  .helixo-urgency-shake { animation: helixo-shake 0.5s ease-in-out infinite; }
</style>

<script src="{{ 'countdown-widget.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Countdown Timer",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": []
}
{% endschema %}
